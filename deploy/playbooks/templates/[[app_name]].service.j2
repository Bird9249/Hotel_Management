[Unit]
Description={{ app_name }} — Hotel Management API (Bun + Elysia)
After=network.target

[Service]
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ server_current }}
EnvironmentFile={{ app_env_dest }}
ExecStart={{ bun_bin }} ./index.ts
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
