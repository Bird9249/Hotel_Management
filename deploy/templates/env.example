# Environment file สำหรับ production
# คัดลอกไปที่ /etc/hotel.env แล้วแก้ค่าตามจริง

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://hotel_user:your_password@localhost:5432/hotel_db

# Better Auth
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret
BETTER_AUTH_BASE_URL=https://hotel.example.com
CORS_ORIGIN=https://hotel.example.com

# S3/MinIO — อัปโหลด avatar / logo โรงแรม (optional แต่แนะนำ)
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=hotel-uploads
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

PUBLIC_BOOKING_ENABLED=true
BOOKING_HOLD_MINUTES=15

# Channel manager / OTA
CHANNEL_SYNC_ENABLED=true
# Bun.cron expression (UTC). In-process Bun.cron needs Bun >= 1.3.12
CHANNEL_SYNC_CRON=*/5 * * * *
# Legacy fallback if CHANNEL_SYNC_CRON is not set
CHANNEL_SYNC_INTERVAL_MS=300000
WEBHOOK_SECRET_CHANNELS=dev-channel-webhook-secret
CHANNEX_API_KEY=
CHANNEX_PROPERTY_ID=

# Optional email
SMTP_HOST=
SMTP_FROM=